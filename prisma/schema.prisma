generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  station_manager
  station_staff
  driver
}

enum BusinessLicenseStatus {
  PENDING
  ACTIVE
  REJECTED
  EXPIRED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BLOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FuelStatus {
  ACTIVE
  INACTIVE
}

enum VehicleTypeStatus {
  ACTIVE
  INACTIVE
}

enum StationStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  CONGESTED
  RISK
}

enum TankStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  FULL
  EMPTY
}

enum DispenserStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum NozzleStatus {
  ACTIVE
  BUSY
  OFFLINE
}

enum CameraType {
  rtsp
  http
  webrtc
  mobile_mock
}

enum CameraStatus {
  online
  offline
  testing
}

enum CongestionLevel {
  low
  medium
  high
  critical
}

enum PriceControlMode {
  FIXED // city defines price, no override allowed
  OVERRIDE // stations can override price
}

enum FuelRequestStatus {
  PENDING
  VERIFIED   // 👈 operator has taken it from queue (LOCKED)
  APPROVED
  ASSIGNED
  DISPENSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum RejectionPriority {
  LOW
  MEDIUM
  HIGH
}

enum OrgType {
  GOVERNMENT
  COMPANY
  FACTORY
  NGO
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum TankAuditAction {
  REFILL
  ADJUSTMENT
}

enum AdjustmentType {
  LOSS
  LEAK
  CALIBRATION
  MANUAL_FIX
  CORRECTION
}

enum BusinessLicenseRequestType {
  NEW
  RENEW
}


enum OtpType {
  LOGIN
  REGISTRATION
  VERIFICATION
  RESET_PASSWORD
  CHANGE_PHONE
}








model User {
  id            String  @id @default(uuid())
  full_name     String
  phone         String  @unique
  email         String? @unique
  profile_image String?

  password     String?
  role         UserRole
  // firebase_uid String? @unique
  status       UserStatus @default(ACTIVE)
  gender       Gender @default(MALE)

  driverProfile  DriverProfile?
  managedStation Station? @relation("StationManager")


  // Phone verification
  phoneVerifiedAt DateTime?

  stationId String?
  station   Station? @relation("StationStaff", fields: [stationId], references: [id])

  vehicles     Vehicle[]

  // 👇 FIXED RELATIONS
  fuelRequests FuelRequest[] @relation("FuelRequestUser")
  assignedFuelRequests FuelRequest[] @relation("FuelRequestAssignedTo")

  transactions Transaction[]
  risks        UserRisk[]

  businessLicense BusinessLicense?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

    otpVerifications OtpVerification[]


  notifications Notification[]
}


model DriverProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  age           Int
  nationalId    String    @unique
  licenseNumber String    @unique
  licenseExpiry DateTime?
  isVerified    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}


model OtpVerification {
  id String @id @default(uuid())

  // Nullable because registration may occur before a User exists
  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  phone String

  // Store a hashed OTP, never the plain code
  codeHash String

  type OtpType

  expiresAt DateTime

  verifiedAt DateTime?

  failedAttempts Int @default(0)

  ipAddress String?

  userAgent String?

  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone, type, verifiedAt, expiresAt])
  @@index([userId])
}

model FuelType {
  id    String @id @default(uuid())
  name  String @unique
  price Float

  status FuelStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicleTypes     VehicleType[]
  vehicles         Vehicle[]
  fuelRequests     FuelRequest[]
  transactions     Transaction[]
  stations         StationFuelType[]
  stationFuelPrice StationFuelPrice[]
}

